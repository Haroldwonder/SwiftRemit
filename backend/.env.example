# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/swiftremit

# Stellar Configuration
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM
ADMIN_SECRET_KEY=SXXX...

# API Configuration
PORT=3000
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Verification Settings
VERIFICATION_INTERVAL_HOURS=24
MIN_TRUSTLINE_COUNT=10
MIN_REPUTATION_SCORE=50

# SEP-24 Fiat On/Off Ramp Configuration
# Format: SEP24_ENABLED_<ANCHOR_ID>=true|false
# SEP24_SERVER_<ANCHOR_ID>=https://anchor.example.com
# SEP24_WEBHOOK_<ANCHOR_ID>=https://your-server.com/webhooks/anchor
# SEP24_POLL_INTERVAL_<ANCHOR_ID>=5 (minutes)
# SEP24_TIMEOUT_<ANCHOR_ID>=30 (minutes)
#
# Example for anchor-1:
# SEP24_ENABLED_ANCHOR_1=true
# SEP24_SERVER_ANCHOR_1=https://moneygram.stellar.org/sep24
# SEP24_WEBHOOK_ANCHOR_1=https://your-server.com/webhooks/anchor
# SEP24_POLL_INTERVAL_ANCHOR_1=5
# SEP24_TIMEOUT_ANCHOR_1=30

# SMTP Email Configuration (used for agent KYC status notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@swiftremit.example

# SEP-12 Business KYC Anchor Configuration
SEP12_KYC_SERVER=https://kyc.anchor.example.com
SEP12_AUTH_TOKEN=your_sep12_auth_token
