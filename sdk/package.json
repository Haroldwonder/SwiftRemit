{
  "name": "@swiftremit/sdk",
  "version": "1.0.0",
  "description": "TypeScript client SDK for the SwiftRemit Soroban smart contract",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/testing/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "release": "npm run build && npm publish --access public --provenance"
  },
  "keywords": [
    "stellar",
    "soroban",
    "swiftremit",
    "remittance",
    "usdc"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@stellar/stellar-sdk": ">=13.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@stellar/stellar-sdk": "^13.0.0",
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
